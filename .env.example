# OTP Service Configuration
# Leave empty to disable OTP verification
# Add any value to enable OTP verification (e.g., your email service API key)
VITE_OTP_SERVICE_KEY=

# Example with OTP enabled:
# VITE_OTP_SERVICE_KEY=your-email-service-api-key-here

# When VITE_OTP_SERVICE_KEY is empty or not set:
# - Signup creates account immediately without OTP
# - User can login right after signup

# When VITE_OTP_SERVICE_KEY is set (any value):
# - Signup creates account
# - OTP sent to user's email
# - User must verify OTP before account is activated
# - Two-factor authentication enabled
